/**
 * Head.astro — Custom Starlight Head override.
 *
 * Responsibilities:
 *   1. Inject JSON-LD structured data (Schema.org) for rich results and AI Overviews:
 *      - WebSite + SearchAction (homepage ES + EN) — enables Google Sitelinks Searchbox
 *      - Organization enriquecido (homepage only, ES + EN) — knowsAbout, areaServed, sameAs
 *      - TechArticle enriquecido (every doc page) — wordCount, articleSection, keywords
 *      - FAQPage + Speakable (FAQ pages) — voice search (Google Assistant + Siri)
 *      - DefinedTermSet with product glossary (Segmentation-related pages)
 *      - BreadcrumbList (all pages except homepage)
 *   2. Inject og:image per section (segmentacion, analitica, nevent-ai, default).
 *   3. Resource hints: preconnect to GA4 + FeelBack (-100–200 ms LCP).
 *
 * Important: Starlight calls <Head /> without props. Route data must be read
 * from `Astro.locals.starlightRoute`, not from `Astro.props`.
 *
 * This component renders AFTER the default Starlight <Head> (via the components override),
 * so it MUST NOT duplicate tags already emitted by Starlight:
 *   canonical, hreflang, og:title, og:description, og:url, og:locale, og:type,
 *   og:site_name, twitter:card, description, viewport, charset.
 *
 * Per-page og:image override:
 *   Add `ogImage: /my-custom-image.png` to any page's frontmatter.
 *
 * Registration in astro.config.mjs:
 *   starlight({ components: { Head: './src/components/Head.astro' } })
 */

import Default from '@astrojs/starlight/components/Head.astro';

// ── Access route data from locals (Starlight's canonical pattern) ─────────────
const starlightRoute = Astro.locals.starlightRoute;

// Guard for special pages (404) that may not have a full route context
const entry = starlightRoute?.entry;
const hasEntry = entry != null;
const locale = starlightRoute?.locale;

const SITE = 'https://help.nevent.ai';

// ── Derive canonical URL ─────────────────────────────────────────────────────
// entry.id is the file path relative to src/content/docs, e.g. "nevent-ai/faq.mdx"
const rawId = hasEntry ? (entry.id ?? '') : '';
const slug = rawId.replace(/\.(mdx?|astro)$/, '').replace(/\/index$/, '');
// EN homepage: entry.id = 'en/index' → slug = 'en' after stripping /index suffix.
// We must also treat slug === 'en' as root so the EN homepage is handled correctly.
const isRoot = slug === 'index' || slug === '' || slug === 'en';

const langPrefix = locale === 'en' ? '/en' : '';
// For root pages: canonicalUrl = SITE + langPrefix + '/'
// For deep pages: strip locale prefix from slug, then prepend langPrefix.
const pageSlug = isRoot ? '' : `/${slug.replace(/^en\//, '')}`;
const canonicalUrl = `${SITE}${langPrefix}${pageSlug}/`;

// ── Page metadata ─────────────────────────────────────────────────────────────
const pageTitle = hasEntry ? (entry.data.title ?? 'Nevent Help Center') : 'Nevent Help Center';
const pageDescription = hasEntry
  ? (entry.data.description ?? 'Documentación oficial de Nevent AI')
  : 'Documentación oficial de Nevent AI';
const inLanguage = locale === 'en' ? 'en' : 'es';

// lastUpdated from Starlight (ISO string or Date)
const rawLastUpdated = hasEntry ? entry.data.lastUpdated : undefined;
const dateModified = rawLastUpdated
  ? rawLastUpdated instanceof Date
    ? rawLastUpdated.toISOString()
    : String(rawLastUpdated)
  : new Date().toISOString().split('T')[0];

// ── Route classification ──────────────────────────────────────────────────────
// slug is relative path without locale prefix and without extension
const isFaqPage =
  slug === 'nevent-ai/preguntas-frecuentes' ||
  slug === 'en/nevent-ai/faq' ||
  slug === 'segmentacion/motor-segmentacion/faq' ||
  slug === 'en/segmentation/segmentation-engine/faq' ||
  slug === 'analitica/faq' ||
  slug === 'en/analytics/faq';

// ── Section detection for articleSection + og:image + DefinedTermSet ──────────
/**
 * Returns the human-readable article section from the slug path.
 * Used in TechArticle.articleSection for Google's structured-data carousel.
 */
function getArticleSection(slugPath: string, lang: string): string {
  const clean = slugPath.replace(/^en\//, '');
  if (clean.startsWith('segmentacion/') || clean.startsWith('segmentation/')) {
    return lang === 'en' ? 'Audience Segmentation' : 'Segmentación de audiencia';
  }
  if (clean.startsWith('analitica/') || clean.startsWith('analytics/')) {
    return lang === 'en' ? 'Event Analytics' : 'Analítica de eventos';
  }
  if (clean.startsWith('nevent-ai/')) {
    return lang === 'en' ? 'Nevent AI' : 'Nevent AI';
  }
  return lang === 'en' ? 'Help Center' : 'Centro de ayuda';
}

const articleSection = getArticleSection(slug, inLanguage);

/**
 * Returns per-section og:image URL.
 * Strategy: static images in public/og/ (one per section category).
 * TODO: Replace with dynamically generated images (satori) for v2.
 */
function getOgImageUrl(slugPath: string, frontmatterOverride?: string): string {
  if (frontmatterOverride) return `${SITE}${frontmatterOverride}`;
  if (slugPath === 'index' || slugPath === '' || slugPath === 'en') {
    return `${SITE}/og/og-home.png`;
  }
  const clean = slugPath.replace(/^en\//, '');
  if (clean.startsWith('segmentacion/') || clean.startsWith('segmentation/')) {
    return `${SITE}/og/og-segmentacion.png`;
  }
  if (clean.startsWith('analitica/') || clean.startsWith('analytics/')) {
    return `${SITE}/og/og-analitica.png`;
  }
  if (clean.startsWith('nevent-ai/')) {
    return `${SITE}/og/og-nevent-ai.png`;
  }
  return `${SITE}/og/og-default.png`;
}

const ogImageOverride = hasEntry
  ? ((entry.data as Record<string, unknown>).ogImage as string | undefined)
  : undefined;
const ogImageUrl = getOgImageUrl(slug, ogImageOverride);

/**
 * Returns page keywords from section + page title for TechArticle enrichment.
 */
function getPageKeywords(slugPath: string, title: string, lang: string): string[] {
  const base: string[] = lang === 'en'
    ? ['Nevent', 'event marketing', 'live events', 'CRM for events']
    : ['Nevent', 'marketing de eventos', 'eventos en vivo', 'CRM para eventos'];
  const clean = slugPath.replace(/^en\//, '');
  if (clean.startsWith('segmentacion/') || clean.startsWith('segmentation/')) {
    return [
      ...base,
      ...(lang === 'en'
        ? ['audience segmentation', 'fan segmentation', 'RFM analysis', 'fan targeting']
        : ['segmentación de audiencia', 'segmentación de fans', 'análisis RFM', 'targeting de fans']),
    ];
  }
  if (clean.startsWith('analitica/') || clean.startsWith('analytics/')) {
    return [
      ...base,
      ...(lang === 'en'
        ? ['event analytics', 'campaign analytics', 'event performance', 'audience data']
        : ['analítica de eventos', 'analítica de campañas', 'rendimiento de eventos', 'datos de audiencia']),
    ];
  }
  if (clean.startsWith('nevent-ai/')) {
    return [
      ...base,
      ...(lang === 'en'
        ? ['Nevent AI', 'AI event marketing', 'MCP', 'Claude integration', 'ChatGPT for events']
        : ['Nevent IA', 'marketing de eventos con IA', 'MCP', 'integración Claude', 'ChatGPT para eventos']),
    ];
  }
  return base;
}

const pageKeywords = getPageKeywords(slug, pageTitle, inLanguage);

// ── Pages where DefinedTermSet glossary is injected ───────────────────────────
// We inject on any segmentation page (the terms are Nevent product-specific concepts)
const isSegmentationPage =
