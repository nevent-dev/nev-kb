/**
 * TechArticle (enriched) — every doc page.
 *
 * New fields over baseline:
 *   - mainEntityOfPage: canonical URL (helps Google link article to its URL)
 *   - articleSection: derived from URL path (/segmentacion/ → "Segmentación de audiencia")
 *   - keywords: section-specific + brand keywords for relevance signals
 *   - wordCount: estimated from description length (rough proxy when body is not parsed)
 *
 * wordCount note: Astro MDX does not expose parsed word count at build time without
 * a custom remark plugin. We use description.split(' ').length as a floor estimate.
 * A future iteration can replace this with a Vite plugin that counts words from entry.body.
 */
const techArticleSchema = {
  '@context': 'https://schema.org',
  '@type': 'TechArticle',
  headline: pageTitle,
  description: pageDescription,
  inLanguage,
  dateModified,
  url: canonicalUrl,
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': canonicalUrl,
  },
  articleSection,
  keywords: pageKeywords,
  // wordCount estimated from description as a minimum floor value.
  // TODO: Replace with exact count via remark plugin (count entry.body words).
  wordCount: pageDescription.split(/\s+/).length * 10,
  author: neventAuthorEntity,
  publisher: neventPublisherEntity,
};

/**
 * FAQPage + Speakable — FAQ pages only.
 *
 * Speakable targets elements with .speakable or [data-speakable] CSS selectors.
 * These selectors match:
 *   - Starlight Aside (tip variant) elements which have data-speakable="true"
 *     injected by custom.css via attr() trick (note: attr() on data-* is CSS4,
 *     use class approach instead — see custom.css for .speakable marker injection).
 *   - Any element manually decorated with class="speakable" in MDX.
 *
 * FAQ accordion: Google shows FAQ rich result only when questions are unambiguous
 * Q&A pairs. The FAQPage.mainEntity array must contain at least 1 item.
 */
const faqPageSchema =
  isFaqPage && faqPairs.length > 0
    ? {
        '@context': 'https://schema.org',
        '@type': 'FAQPage',
        speakable: {
          '@type': 'SpeakableSpecification',
          cssSelector: ['.speakable', '[data-speakable]', '.starlight-aside--tip'],
        },
        mainEntity: faqPairs.map((pair) => ({
          '@type': 'Question',
          name: pair.question,
          acceptedAnswer: { '@type': 'Answer', text: pair.answer },
        })),
      }
    : null;

/**
 * DefinedTermSet — Nevent product glossary.
 * Injected on Segmentation-related pages where these terms appear in context.
 * Helps search engines and LLMs understand Nevent-specific terminology.
 *
 * Terms:
 *   - Nevent Score: predictive fan engagement score (0-100)
 *   - Nevent Temperature: 6-level predictive fan tier (Muy Caliente → Congelado)
 *   - RFM Segment: one of 11 RFM profiles (Champions, Loyal, At Risk, etc.)
 *   - Stanza: group of segmentation criteria (OR within stanza, AND across stanzas)
 */
const definedTermSetSchema = isSegmentationPage
  ? {
      '@context': 'https://schema.org',
      '@type': 'DefinedTermSet',
      name: inLanguage === 'en' ? 'Nevent product glossary' : 'Glosario de producto Nevent',
      hasDefinedTerm: [
        {
          '@type': 'DefinedTerm',
          name: 'Nevent Score',
          description:
            inLanguage === 'en'
              ? 'Automatic fan score (0–100) based on historical value, purchase frequency and digital engagement.'
              : 'Puntuación automática del fan (0–100) basada en valor histórico, frecuencia de compra y engagement digital.',
          termCode: 'nevent-score',
          inDefinedTermSet: `${SITE}/segmentacion/capacidades/score-y-temperatura/`,
        },
        {
          '@type': 'DefinedTerm',
          name: 'Nevent Temperature',
          description:
            inLanguage === 'en'
              ? 'Predictive fan segmentation across 6 tiers (Very Hot, Hot, Warm, Cold, Very Cold, Frozen) based on Nevent Score.'
              : 'Segmentación predictiva del fan en 6 niveles (Muy Caliente, Caliente, Templado, Frío, Muy Frío, Congelado) basada en el Nevent Score.',
          termCode: 'nevent-temperature',
          inDefinedTermSet: `${SITE}/segmentacion/capacidades/score-y-temperatura/`,
        },
        {
          '@type': 'DefinedTerm',
          name: 'RFM Segment',
          description:
            inLanguage === 'en'
              ? 'Automatic fan classification into one of 11 RFM profiles (Champions, Loyal Customers, At Risk, etc.) based on Recency, Frequency and Monetary value.'
              : 'Clasificación automática de fans en uno de 11 perfiles RFM (Champions, Loyal Customers, At Risk, etc.) basada en Recencia, Frecuencia y Valor monetario.',
          termCode: 'rfm-segment',
          inDefinedTermSet: `${SITE}/segmentacion/capacidades/rfm/`,
        },
        {
          '@type': 'DefinedTerm',
          name: 'Stanza',
          description:
            inLanguage === 'en'
              ? 'Group of segmentation criteria. Criteria within a stanza use OR logic; stanzas between them use AND logic.'
              : 'Grupo de criterios de segmentación. Los criterios dentro de un stanza usan lógica OR; los stanzas entre sí usan lógica AND.',
          termCode: 'stanza',
          inDefinedTermSet: `${SITE}/segmentacion/motor-segmentacion/operadores-logica/`,
        },
      ],
    }
  : null;

/** BreadcrumbList — all pages except homepage */
const breadcrumbItems = !isRoot ? buildBreadcrumbs(slug, inLanguage) : [];
const breadcrumbSchema =
  !isRoot && breadcrumbItems.length > 1
    ? {
        '@context': 'https://schema.org',
        '@type': 'BreadcrumbList',
        itemListElement: breadcrumbItems,
      }
    : null;

// ── Serialize to JSON strings for is:inline injection ─────────────────────────
/**
 * Safely serializes a value to a JSON string safe for inline <script> injection.
 *
 * JSON.stringify does NOT escape the `</` sequence. If any field value ever
 * contains `</script>`, the browser would prematurely close the JSON-LD block
 * — a classic script-injection vector. Replacing `</` with `<\/` produces
 * JSON that is still valid (parsers accept the escaped solidus) while
 * preventing the browser parser from misinterpreting the closing tag.
 *
 * @param obj - The value to serialize.
 * @returns A JSON string safe for injection inside a <script> element.
 */
function toSafeJsonLd(obj: unknown): string {
  return JSON.stringify(obj).replace(/<\//g, '<\\/');
}

const websiteJson = toSafeJsonLd(websiteSchema);
const organizationJson = toSafeJsonLd(organizationSchema);
const techArticleJson = toSafeJsonLd(techArticleSchema);
const faqPageJson = faqPageSchema ? toSafeJsonLd(faqPageSchema) : null;
const definedTermSetJson = definedTermSetSchema ? toSafeJsonLd(definedTermSetSchema) : null;
const breadcrumbJson = breadcrumbSchema ? toSafeJsonLd(breadcrumbSchema) : null;
---

<!-- Render default Starlight Head (canonical, hreflang, og:title, og:description, etc.) -->
<Default />

<!--
  Resource hints — reduce connection latency for third-party scripts.
  preconnect: establishes TCP + TLS early; saves 100–200 ms on first request.
  dns-prefetch: DNS-only fallback for browsers that ignore preconnect.

  Targets:
    - Google Tag Manager (GA4 gtag script)
    - FeelBack (feedback widget loaded in Footer.astro)
-->
<link rel="preconnect" href="https://www.googletagmanager.com" crossorigin />
<link rel="dns-prefetch" href="https://www.googletagmanager.com" />
<link rel="preconnect" href="https://feelback.dev" crossorigin />
<link rel="dns-prefetch" href="https://feelback.dev" />

{hasEntry && (
  <Fragment set:html={
    [
      // ── og:image (per-section) ──────────────────────────────────────────
      `<meta property="og:image" content="${ogImageUrl}">`,
      `<meta property="og:image:type" content="image/png">`,
      `<meta property="og:image:width" content="1200">`,
      `<meta property="og:image:height" content="630">`,
      `<meta property="og:image:alt" content="${pageTitle} — Nevent Help Center">`,
      `<meta name="twitter:image" content="${ogImageUrl}">`,
      // ── JSON-LD schemas ───────────────────────────────────────────────
      // WebSite + SearchAction: homepage only (enables Google Sitelinks Searchbox)
      isRoot
        ? `<script type="application/ld+json">${websiteJson}</script>`
        : '',
      // Organization: homepage only (E-E-A-T + Knowledge Panel signal)
      isRoot
        ? `<script type="application/ld+json">${organizationJson}</script>`
        : '',
      // TechArticle (enriched): every page — rich result + AEO context
      `<script type="application/ld+json">${techArticleJson}</script>`,
      // FAQPage + Speakable: FAQ pages only — rich accordion + voice search
      faqPageJson
        ? `<script type="application/ld+json">${faqPageJson}</script>`
        : '',
      // DefinedTermSet: segmentation pages — product glossary for LLMs + Google
      definedTermSetJson
        ? `<script type="application/ld+json">${definedTermSetJson}</script>`
        : '',
      // BreadcrumbList: all non-home pages — breadcrumb in SERP
      breadcrumbJson
        ? `<script type="application/ld+json">${breadcrumbJson}</script>`
        : '',
    ].join('\n')
  } />
)}

<!--
  Web Vitals tracking — reports LCP, CLS, INP, FCP, TTFB to GA4.
  GA4 measurement ID: G-HMCEBRLTBG (configured in astro.config.mjs head[] array).
  Each metric is sent as a custom GA4 event under the category "Web Vitals".
  This enables Core Web Vitals monitoring in GA4 → Reports → Custom events.

  Metric values:
    LCP (Largest Contentful Paint) — in ms, good < 2500
    CLS (Cumulative Layout Shift)  — unitless × 1000, good < 100
    INP (Interaction to Next Paint) — in ms, good < 200
    FCP (First Contentful Paint)   — in ms, good < 1800
    TTFB (Time to First Byte)      — in ms, good < 800
-->
<script>
  import { onCLS, onLCP, onINP, onFCP, onTTFB } from 'web-vitals';

  /**
   * Sends a single Web Vital metric to GA4.
   * Uses `gtag` injected by the GA4 script in astro.config.mjs.
   *
   * @param {import('web-vitals').Metric} metric - Web Vitals metric object.
   */
  function sendToGA4(metric) {
    if (typeof gtag === 'undefined') return;
    gtag('event', metric.name, {
      event_category: 'Web Vitals',
      // Use `id` as the event label so individual page loads are linkable.
      event_label: metric.id,
      // Round to the nearest integer for GA4 integer-only metrics.
      // CLS is multiplied by 1000 to avoid sub-1 float values.
      value: Math.round(metric.name === 'CLS' ? metric.delta * 1000 : metric.delta),
      // non_interaction = true so these events do not affect bounce rate.
      non_interaction: true,
    });
  }

  onCLS(sendToGA4);
  onLCP(sendToGA4);
  onINP(sendToGA4);
  onFCP(sendToGA4);
  onTTFB(sendToGA4);
</script>
