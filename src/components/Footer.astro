---
/**
 * Footer.astro — Custom Starlight Footer override.
 *
 * Responsibilities:
 *   1. Render the FeelBack Yes/No feedback widget above the default Starlight footer.
 *      Widget prompts users "¿Te ha resultado útil esta página?" (ES) /
 *      "Did you find this page helpful?" (EN).
 *   2. Detect page locale from Starlight's route locals.
 *   3. Fall through to the default Starlight <Footer /> for pagination, edit links, etc.
 *
 * FeelBack setup:
 *   - contentSetId is a PLACEHOLDER. Samuel must:
 *     1. Create a free account at https://app.feelback.dev
 *     2. Create a content set (Yes/No type)
 *     3. Replace FEELBACK_CONTENT_SET_ID_HERE with the generated ID
 *   - Until the real ID is set, the widget renders with placeholder text
 *     and API calls will fail silently (FeelBack handles this gracefully).
 *
 * Registration in astro.config.mjs:
 *   starlight({ components: { Footer: './src/components/Footer.astro' } })
 *
 * @see https://www.feelback.dev/docs/integrations/astro
 */

import Default from '@astrojs/starlight/components/Footer.astro';
import FeelbackYesNo from 'astro-feelback/components/FeelbackYesNo.astro';
import 'astro-feelback/styles/feelback.css';

// ── Detect locale from Starlight route context ────────────────────────────────
const starlightRoute = Astro.locals.starlightRoute;
const locale = starlightRoute?.locale ?? 'root';
const isEnglish = locale === 'en';

// ── Localised copy ────────────────────────────────────────────────────────────
const textQuestion = isEnglish
  ? 'Did you find this page helpful?'
  : '¿Te ha resultado útil esta página?';
const textAnswer = isEnglish
  ? 'Thanks for your feedback!'
  : '¡Gracias por tu opinión!';

/**
 * Content set ID from feelback.dev panel.
 * TODO: Replace with the real ID after creating the account at https://app.feelback.dev
 */
const FEELBACK_CONTENT_SET_ID = 'FEELBACK_CONTENT_SET_ID_HERE';
---

<!--
  Feedback widget — rendered above the standard Starlight footer.
  Uses FeelBack Yes/No (thumbs up / thumbs down) preset.
  Behaviour "switch" hides the buttons after the user votes and shows the thank-you message.
-->
<div class="nev-feedback-wrapper">
  <FeelbackYesNo
    contentSetId={FEELBACK_CONTENT_SET_ID}
    preset="like-dislike"
    behavior="switch"
    textQuestion={textQuestion}
    textAnswer={textAnswer}
    showCount={false}
    revokable={false}
  />
</div>

<!-- Default Starlight footer (pagination arrows, edit on GitHub link, etc.) -->
<Default />

<style>
  /**
   * Wrapper styles for the feedback widget.
   * Positions the widget at the top of the footer area with consistent spacing.
   * Uses Starlight CSS custom properties for colour consistency in light/dark mode.
   */
  .nev-feedback-wrapper {
    padding: var(--sl-content-pad-x, 1rem) 0;
    border-top: 1px solid var(--sl-color-hairline-light, #e2e8f0);
    margin-bottom: 1rem;
    display: flex;
    align-items: center;
    justify-content: flex-start;
  }

  /* Tune FeelBack built-in styles to fit Starlight's visual language */
  .nev-feedback-wrapper :global(.feelback-yesno) {
    --feelback-color-primary: var(--sl-color-accent, #8B5CF6);
    font-size: 0.875rem;
    color: var(--sl-color-text-accent, inherit);
  }

  .nev-feedback-wrapper :global(.feelback-text) {
    margin-right: 0.75rem;
    font-weight: 500;
  }
</style>
